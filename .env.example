# =============================================================================
# PRIVATE CORPORATE AI — Variabili d'Ambiente
# Copia questo file in `.env` e personalizza i valori prima del deploy.
# NON committare mai il file `.env` su Git.
# =============================================================================

# -----------------------------------------------------------------------------
# MODALITÀ DI DEPLOY
# -----------------------------------------------------------------------------
# Scegli la modalità in base all'hardware disponibile:
#
#   gpu   → Modalità FULL  — Richiede GPU NVIDIA con CUDA (16-24GB VRAM)
#            Avvio: docker compose --env-file .env up -d
#
#   cpu   → Modalità LITE  — Solo CPU + RAM (nessuna GPU richiesta)
#            Avvio: docker compose -f docker-compose.yaml \
#                     -f docker-compose.lite.yaml --env-file .env up -d
#
# NOTA: In modalità LITE usa modelli quantizzati (q4_K_M) per ridurre RAM e
# migliorare la velocità di inferenza. Vedi sezione MODELLI LLM più avanti.
# -----------------------------------------------------------------------------
DEPLOY_MODE=gpu

# -----------------------------------------------------------------------------
# CONFIGURAZIONE LLM (Ollama)
# -----------------------------------------------------------------------------
# --- MODELLI CONSIGLIATI MODALITÀ GPU (16-24GB VRAM) ---
#   gemma2:9b             → Ottimo ITA/ENG, bilanciato         (VRAM ~8GB)
#   mistral:7b            → Veloce, uso generale               (VRAM ~6GB)
#   deepseek-r1:14b       → Ragionamento avanzato              (VRAM ~12GB)
#   mixtral:8x7b          → MOE, eccellente per RAG            (VRAM ~26GB Q4)
#   llama3.1:8b           → Meta, multilingua                  (VRAM ~6GB)
#
# --- MODELLI CONSIGLIATI MODALITÀ LITE (CPU-only, 8-32GB RAM) ---
#   tinyllama:1.1b                → Ultra-leggero, test rapidi         (RAM ~1GB)
#   phi3:mini                     → Microsoft, ottimo rapporto         (RAM ~2.3GB)
#   gemma2:2b                     → Google, compatto e capace          (RAM ~1.6GB)
#   mistral:7b-instruct-q4_K_M    → Quantizzato 4-bit, bilanciato      (RAM ~4.1GB)
#   llama3.2:3b                   → Meta, leggero e capace             (RAM ~2GB)
#   qwen2.5:7b-instruct-q4_K_M    → Eccellente multilingua ITA/ENG     (RAM ~4.4GB)
#
# NOTA: I modelli con suffisso q4_K_M sono quantizzati a 4-bit:
#   - Dimensione ridotta del ~60% rispetto al modello float16
#   - Qualità ~97% del modello originale
#   - Fortemente raccomandati per la modalità LITE
# -----------------------------------------------------------------------------
LLM_MODEL=gemma2:9b

# Modello di embedding — nomic-embed-text e' leggero (274MB) e multilingua
# Alternativa CPU-lite: all-minilm (23MB, piu' veloce ma meno accurato)
EMBEDDING_MODEL=nomic-embed-text

# Dimensione del contesto (token). Ridurre a 2048 in modalita' LITE per risparmiare RAM
LLM_CONTEXT_WINDOW=4096

# Temperatura: 0.0 = deterministico, 1.0 = creativo. Per RAG corporate: 0.1-0.3
LLM_TEMPERATURE=0.2

# Numero massimo di thread CPU utilizzati da Ollama (modalita' LITE)
# 0 = automatico (usa tutti i core disponibili)
# Consiglio: imposta al numero di core fisici (es: 8 su un 16-thread)
OLLAMA_CPU_THREADS=0

# Layer del modello caricati su GPU. In modalita' LITE deve essere 0 (tutto su CPU).
# In modalita' GPU viene ignorato (Ollama usa tutta la VRAM disponibile).
OLLAMA_NUM_GPU_LAYERS=0

# -----------------------------------------------------------------------------
# CONFIGURAZIONE QDRANT (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=corporate_docs
QDRANT_API_KEY=changeme_qdrant_key

# -----------------------------------------------------------------------------
# CONFIGURAZIONE RAG PIPELINE
# -----------------------------------------------------------------------------
# Dimensione chunk (caratteri). Ridurre a 500-700 in modalita' LITE
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Numero chunk recuperati per query. Ridurre a 3 in modalita' LITE
TOP_K_RESULTS=5

# -----------------------------------------------------------------------------
# CONFIGURAZIONE OPEN WEBUI
# -----------------------------------------------------------------------------
WEBUI_SECRET_KEY=changeme_super_secret_key_32chars
WEBUI_AUTH=true
WEBUI_DEFAULT_USER_ROLE=user

# -----------------------------------------------------------------------------
# CONFIGURAZIONE NGINX
# -----------------------------------------------------------------------------
NGINX_HOST=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# CONFIGURAZIONE GENERALE
# -----------------------------------------------------------------------------
TZ=Europe/Rome
LOG_LEVEL=INFO
UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# CONFIGURAZIONE DOCUMENT CONSOLE
# -----------------------------------------------------------------------------
# URL base per le chiamate API dalla console verso il RAG backend
# In produzione deve corrispondere al path Nginx configurato
CONSOLE_RAG_API_BASE=/api/rag

# Abilita/disabilita la console (rimuovi il servizio da compose per disabilitarla)
# Non richiede variabili aggiuntive: la sicurezza è delegata a Nginx
